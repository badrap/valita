{
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.exclude": {
    "node_modules": true,
    "dist": true,
    ".cache": true
  },
  "oxc.typeAware": true,
  "oxc.unusedDisableDirectives": "deny",
  "typescript.tsdk": "node_modules/typescript/lib"
}
